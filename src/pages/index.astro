---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";

import coperta from "@assets/coperta.png";
import brasov from "@assets/brasov.svg";
import retea from "@assets/retea.svg";

import { participanti } from "../lib/participanti.js";

const manuale = ["Manual 1", "Manual 2", "Manual 3"];
const programe = ["1", "2", "3"];
const sponsori = ["Sponsor 1", "Sponsor 2", "Sponsor 3"];

const images = import.meta.glob<{ default: ImageMetadata }>(
    "@assets/logo_altii/*.png",
);
---

<Layout>
    <Header />

    <div class="relative overflow-hidden pt-56 pb-26">
        <div class="absolute -top-50 left-0">
            <Image src={coperta} class="" alt="" />
        </div>
        <div
            class="absolute top-0 left-0 bg-linear-to-b from-[#2F0060] from-10% via-primary/65 via-70% to-black/90 z-1 w-full h-full"
        >
        </div>
        <div
            class="pl-20 text-white text-[2.75rem] z-10 w-fit"
            style="position: inherit"
        >
            <div class="relative w-fit">
                <Image class="absolute top-1/3 left-1/2" src={retea} alt="" />
                <h1
                    class="text-[10rem] text-shadow-[0.66px_2.66px_15.49px_rgb(0_0_0_/_0.7)] font-extrabold"
                >
                    NETWORK FEST
                </h1>
                <Image
                    class="absolute left-1/2 top-37 -translate-x-58"
                    src={brasov}
                    alt=""
                />
            </div>
            <p class="pt-26">Evenimentul care ne unește</p>
            <div class="py-10">
                <time><b>25 aprilie 2026</b></time>
                <div>Interval orar: <b>11:00-16:00</b></div>
            </div>
            <p>Locația: Afi MALL, zona Food Court</p>
        </div>
    </div>

    <div>
        <h1 id="manuale" class="pt-8 text-center text-primary font-bold">
            Manuale
        </h1>
        <div class="flex flex-row gap-4 justify-center py-8 shadow-black/50">
            {
                manuale.map((titlu) => (
                    <div
                        class="flex flex-col border-1 rounded-[10px] p-8 gap-6 items-center border-black/5 shadow-lg shadow-black/3"
                    >
                        {titlu}
                        <svg
                            width="40"
                            viewBox="0 0 134 149"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M7.41699 126.084V31.1501C7.41699 22.8427 7.41699 18.6889 9.03376 15.5159C10.4558 12.7248 12.725 10.4556 15.5162 9.03351C18.6892 7.41675 22.843 7.41675 31.1504 7.41675H102.351C110.658 7.41675 114.812 7.41675 117.985 9.03351C120.776 10.4556 123.045 12.7248 124.467 15.5159C126.084 18.6889 126.084 22.8427 126.084 31.1501V111.25H22.2504C14.0581 111.25 7.41699 117.891 7.41699 126.084ZM7.41699 126.084C7.41699 134.276 14.0581 140.917 22.2504 140.917H126.084M44.5004 37.0835H89.0005M44.5004 66.7502H89.0005M118.667 111.25V140.917"
                                stroke="#7625C5"
                                stroke-width="14.8334"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            />
                        </svg>
                        manual de folosire lorem ipsum
                    </div>
                ))
            }
        </div>
    </div>

    <div class="py-8 bg-black/5">
        <h1
            id="program"
            class="py-8 text-center bg-primary text-white font-semibold"
        >
            Program
        </h1>
        <div class="bg-white">
            {
                programe.map((titlu) => (
                    <div
                        class="bg-white p-8 border-b border-black/5 lg:w-260 m-auto text-primary"
                    >
                        <div class="divide-x-1">
                            <b class="pr-5"> ora {titlu}</b><sb class="pl-3"
                            >Deschidere</sb>
                        </div>
                        <div class="text-black/30 thin">
                            nu stiu care e programul
                        </div>
                    </div>
                ))
            }
        </div>
    </div>

    <div>
        <div class="bg-black/5">
            <h1 id="participanti">
                <div
                    class="text-primary font-bold bg-white text-center p-10"
                >
                    Participanți
                </div>
            </h1>
            <div class="flex flex-row justify-center flex-wrap bg-white gap-2">
                {
                    participanti.map((p) => (
                        <div
                            class="flex flex-col items-center bg-white p-5 text-black/40 text-center border border-black/5"
                        >
                            {
                                p.logo !== ""
                                    ? (
                                    <Image
                                        alt=""
                                        class="pb-2"
                                        height={84}
                                        src={images
                                            [`/src/assets/logo_altii/${p.logo}`]()}
                                    />
                                )
                                : <b class="py-5">{p.nume}</b>
                            }
                            <div
                                class="text-thin text-black/80 text-xs w-[60ch]"
                            >
                                {p.descriere}
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>

    <footer >
    </footer>
</Layout>
